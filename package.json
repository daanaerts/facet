{
  "name": "facet",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "workspaces": [
    "packages/*"
  ],
  "scripts": {
    "check": "bun run scripts/check.ts",
    "test": "bun test",
    "pg:up": "docker compose up -d --wait",
    "pg:down": "docker compose down -v",
    "test:pg": "FACET_TEST_DATABASE_URL=postgres://facet:facet@localhost:5433/facet bun test",
    "typecheck": "tsc -p tsconfig.base.json --noEmit",
    "lint": "biome check .",
    "lint:fix": "biome check --write .",
    "build": "bun run --filter '*' build",
    "build:watch": "bun run --filter '*' build:watch",
    "publint": "bunx publint packages/core && bunx publint packages/http && bunx publint packages/cli && bunx publint packages/mcp && bunx publint packages/agent && bunx publint packages/surface-kit",
    "attw": "bunx attw --pack --profile esm-only packages/core && bunx attw --pack --profile esm-only packages/http && bunx attw --pack --profile esm-only packages/cli && bunx attw --pack --profile esm-only packages/mcp && bunx attw --pack --profile esm-only packages/agent && bunx attw --pack --profile esm-only packages/surface-kit",
    "changeset": "changeset",
    "version:packages": "changeset version",
    "release": "bun run build && changeset publish"
  },
  "dependencies": {
    "@facet/agent": "workspace:*",
    "@facet/cli": "workspace:*",
    "@facet/core": "workspace:*",
    "@facet/http": "workspace:*",
    "@facet/mcp": "workspace:*",
    "@facet/surface-kit": "workspace:*",
    "@modelcontextprotocol/sdk": "^1.29.0",
    "zod": "^4.0.0"
  },
  "devDependencies": {
    "@arethetypeswrong/cli": "^0.18.1",
    "@biomejs/biome": "^2.2.0",
    "@changesets/cli": "^2.27.10",
    "@types/bun": "latest",
    "drizzle-orm": "^0.45.2",
    "publint": "^0.3.2",
    "tsdown": "^0.15.6",
    "typescript": "^5.9.0"
  }
}
