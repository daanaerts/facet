{
  "name": "@facet/mcp",
  "version": "0.1.0",
  "type": "module",
  "description": "The Facet MCP surface: a stdio MCP server exposing one tool per capability, generic over the registry.",
  "license": "MIT",
  "exports": {
    ".": {
      "bun": "./src/index.ts",
      "import": {
        "types": "./dist/index.d.ts",
        "default": "./dist/index.js"
      }
    }
  },
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "files": [
    "dist",
    "src"
  ],
  "sideEffects": false,
  "engines": {
    "node": ">=22"
  },
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "build": "tsdown",
    "build:watch": "tsdown --watch"
  },
  "dependencies": {
    "@facet/core": "workspace:*",
    "@facet/surface-kit": "workspace:*",
    "@modelcontextprotocol/sdk": "^1.29.0"
  }
}
