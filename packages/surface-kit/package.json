{
  "name": "@facet/surface-kit",
  "version": "0.1.0",
  "type": "module",
  "description": "Shared host-seam helpers for Facet surfaces: AuthParts -> Context (contextFromParts), claim accessors, and the confirm/idempotency field merge.",
  "license": "MIT",
  "exports": {
    ".": {
      "bun": "./src/index.ts",
      "import": {
        "types": "./dist/index.d.ts",
        "default": "./dist/index.js"
      }
    }
  },
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "files": [
    "dist",
    "src"
  ],
  "sideEffects": false,
  "engines": {
    "node": ">=22"
  },
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "build": "tsdown",
    "build:watch": "tsdown --watch"
  },
  "dependencies": {
    "@facet/core": "workspace:*"
  }
}
