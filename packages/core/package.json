{
  "name": "@facet/core",
  "version": "0.1.0",
  "type": "module",
  "description": "The runtime-pure Facet capability engine: defineCapability + execute(), one chokepoint, every surface.",
  "license": "MIT",
  "exports": {
    ".": {
