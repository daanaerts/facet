{
  "compilerOptions": {
    "target": "ESNext",
    "module": "Preserve",
    "moduleResolution": "bundler",
    "lib": ["ESNext"],
    "types": ["bun"],
    "strict": true,
    "noUncheckedIndexedAccess": true,
    "noImplicitOverride": true,
    "skipLibCheck": true,
    "esModuleInterop": true,
    "resolveJsonModule": true,
    "isolatedModules": true,
    "allowImportingTsExtensions": true,
    "noEmit": true,
    "baseUrl": ".",
    "paths": {
      "@facet/core": ["./packages/core/src/index.ts"],
      "@facet/http": ["./packages/http/src/index.ts"],
      "@facet/cli": ["./packages/cli/src/index.ts"],
      "@facet/mcp": ["./packages/mcp/src/index.ts"],
      "@facet/agent": ["./packages/agent/src/index.ts"],
      "@facet/surface-kit": ["./packages/surface-kit/src/index.ts"],
      "@facet/parity": ["./packages/parity/src/index.ts"]
    }
  },
  "include": ["packages/*/src", "examples", "tests"]
}
